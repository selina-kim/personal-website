---
import { Image } from 'astro:assets';

const { img, imgAlt, imgWidth, imgHeight, name, desc, link, LinkIcon, title } = Astro.props;

export interface Props {
	img: string;
	imgAlt: string;
    imgWidth: number;
    imgHeight: number;
    name: string;
    desc: string;
    link: string;
    LinkIcon: any;
    title: string;
}
---

<div
class="relative w-full max-w-[550px] h-[350px] md:w-[290px] m-4 p-[3px] overflow-hidden rounded-2xl bg-dark-main">
    <div class="relative w-full h-full overflow-hidden rounded-xl">
        <Image src={img} alt={imgAlt} width={imgWidth} height={imgHeight} format="avif" class="absolute top-0 object-cover min-h-[60%]"/>
        <div class="absolute h-full w-full project-fill-gradient">
            <div class="absolute w-full h-full p-3 text-light-main">
                <div class="flex w-full h-[11.5rem]">
                    <a href={link} aria-label={"Project Link"}
                    rel="noopener noreferrer"
                    target="_blank" title={title}
                    class="text-dark-main w-12 m-auto p-2 drop-shadow-gradient bg-white rounded-2xl hover:opacity-100 opacity-80">
                        <LinkIcon/>
                    </a>
                </div>
                <h3 class="mb-2 bg-">{name}</h3>
                <p class="text-left leading-5">{desc}</p>
            </div>
        </div>
    </div>
</div>